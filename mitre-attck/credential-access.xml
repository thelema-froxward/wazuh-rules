<!-- Wazuh Rules: MITRE ATT&CK - Credential Access (TA0006) -->
<!-- Rule IDs: 101250 - 101299 -->
<group name="mitre,credential_access,">

  <rule id="101250" level="12">
    <if_group>syslog</if_group>
    <match type="pcre2">(?i)(\bcat\b\s+\/etc\/shadow|\bawk\b.*\/etc\/shadow|\bsed\b.*\/etc\/shadow)</match>
    <description>T1003.008 - OS Credential Dumping: /etc/shadow file read attempt.</description>
    <mitre>
      <id>T1003.008</id>
    </mitre>
    <group>mitre,credential_access,shadow_dump,</group>
  </rule>

  <rule id="101251" level="10">
    <if_group>syslog</if_group>
    <match type="pcre2">(?i)(\bjohn\b|\bhashcat\b|\bhydra\b|\bmedusa\b|\bncrack\b|\bophcrack\b)</match>
    <description>T1110.002 - Brute Force: Password cracking tool execution detected.</description>
    <mitre>
      <id>T1110.002</id>
    </mitre>
    <group>mitre,credential_access,password_cracking,</group>
  </rule>

  <rule id="101252" level="12">
    <if_group>syslog</if_group>
    <match type="pcre2">(?i)(\bmimikatz\b|\bsekurlsa\b|\bkerberos::list\b|\blsadump\b|\bwce\b\s+-w)</match>
    <description>T1003.001 - OS Credential Dumping: Mimikatz or credential dumping tool detected.</description>
    <mitre>
      <id>T1003.001</id>
    </mitre>
    <group>mitre,credential_access,mimikatz,</group>
  </rule>

  <rule id="101253" level="10">
    <if_group>syslog</if_group>
    <match type="pcre2">(?i)(\btcpdump\b.*port\s+(21|25|110|143|389|445)|\bettercap\b|\bresponder\b)</match>
    <description>T1040 - Network Sniffing: Traffic capture on credential-bearing protocols.</description>
    <mitre>
      <id>T1040</id>
    </mitre>
    <group>mitre,credential_access,network_sniffing,</group>
  </rule>

  <rule id="101254" level="9">
    <if_group>syslog</if_group>
    <match type="pcre2">(?i)(\bgrep\b\s+-[rRi]*\s+.*(password|passwd|secret|token|api_key|credential).*\.(conf|cfg|ini|env|yml|yaml|json|xml|properties))</match>
    <description>T1552.001 - Credentials in Files: Grep search for credentials in config files.</description>
    <mitre>
      <id>T1552.001</id>
    </mitre>
    <group>mitre,credential_access,credential_search,</group>
  </rule>

  <rule id="101255" level="9">
    <if_group>syslog</if_group>
    <match type="pcre2">(?i)(\bfind\b\s+.*-name\s+.*(\.pem|\.key|id_rsa|id_dsa|id_ed25519|\.pfx|\.p12))</match>
    <description>T1552.004 - Private Keys: Search for SSH/TLS private key files.</description>
    <mitre>
      <id>T1552.004</id>
    </mitre>
    <group>mitre,credential_access,key_search,</group>
  </rule>

  <rule id="101256" level="10">
    <if_group>syslog</if_group>
    <match type="pcre2">(?i)(\bkeylogger\b|\bxinput\b\s+test|\bxdotool\b\s+key|\bxev\b|\blogkeys\b)</match>
    <description>T1056.001 - Keylogging: Keylogger or input capture tool detected.</description>
    <mitre>
      <id>T1056.001</id>
    </mitre>
    <group>mitre,credential_access,keylogging,</group>
  </rule>

  <rule id="101257" level="10">
    <if_group>syslog</if_group>
    <match type="pcre2">(?i)(\bcat\b\s+.*\.(bash_history|mysql_history|psql_history|python_history))</match>
    <description>T1552.003 - Bash History: Shell/application history file read — credential harvesting.</description>
    <mitre>
      <id>T1552.003</id>
    </mitre>
    <group>mitre,credential_access,history_read,</group>
  </rule>

  <rule id="101258" level="9">
    <if_group>syslog</if_group>
    <match type="pcre2">(?i)(\bsslstrip\b|\bmitmproxy\b|\bbettercap\b.*sniffer|\barpspoof\b)</match>
    <description>T1557 - Adversary-in-the-Middle: MITM tool execution detected.</description>
    <mitre>
      <id>T1557</id>
    </mitre>
    <group>mitre,credential_access,mitm,</group>
  </rule>

  <rule id="101259" level="10">
    <if_group>syslog</if_group>
    <match type="pcre2">(?i)(\bkerberoast\b|\bGetUserSPNs\b|\bRubeus\b.*kerberoast|\basreproast\b)</match>
    <description>T1558.003 - Kerberoasting: Kerberos ticket extraction tool detected.</description>
    <mitre>
      <id>T1558.003</id>
    </mitre>
    <group>mitre,credential_access,kerberoast,</group>
  </rule>

  <rule id="101260" level="9">
    <if_group>syslog</if_group>
    <match type="pcre2">(?i)(\benv\b\s*$|\bprintenv\b|\bset\b\s*$|strings\s+\/proc\/\d+\/environ)</match>
    <description>T1552.007 - Container API: Environment variable dumping — secret extraction.</description>
    <mitre>
      <id>T1552.007</id>
    </mitre>
    <group>mitre,credential_access,env_dump,</group>
  </rule>

</group>
