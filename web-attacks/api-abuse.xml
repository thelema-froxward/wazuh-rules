<!-- Wazuh Rules: API Abuse Detection -->
<!-- Rule IDs: 100310 - 100329 -->
<group name="web,attack,api_abuse,">

  <rule id="100310" level="6">
    <if_group>web|accesslog</if_group>
    <url type="pcre2">(?i)(\/api\/)</url>
    <status>429</status>
    <description>API Abuse: Rate limit triggered (HTTP 429).</description>
    <mitre>
      <id>T1499</id>
    </mitre>
    <group>web,attack,api_abuse,pci_dss_6.5.10,</group>
  </rule>

  <rule id="100311" level="10" frequency="20" timeframe="60">
    <if_matched_sid>100310</if_matched_sid>
    <same_source_ip />
    <description>API Abuse: Persistent rate limit violations — automated API scraping/abuse.</description>
    <mitre>
      <id>T1499</id>
    </mitre>
    <group>web,attack,api_abuse,pci_dss_6.5.10,pci_dss_11.4,</group>
  </rule>

  <rule id="100312" level="8">
    <if_group>web|accesslog</if_group>
    <url type="pcre2">(?i)(\/api\/.*\b(admin|internal|debug|swagger|openapi|graphql)\b)</url>
    <description>API Abuse: Access to administrative or internal API endpoint.</description>
    <mitre>
      <id>T1190</id>
    </mitre>
    <group>web,attack,api_abuse,pci_dss_6.5.1,</group>
  </rule>

  <rule id="100313" level="7">
    <if_group>web|accesslog</if_group>
    <url type="pcre2">(?i)(\/api\/v\d+\/users\/\d+|\/api\/.*\bid=\d+)</url>
    <status>200</status>
    <description>API Abuse: Sequential ID enumeration on API — potential IDOR/data scraping.</description>
    <mitre>
      <id>T1190</id>
    </mitre>
    <group>web,attack,api_abuse,pci_dss_6.5.1,</group>
  </rule>

  <rule id="100314" level="10" frequency="50" timeframe="60">
    <if_matched_sid>100313</if_matched_sid>
    <same_source_ip />
    <description>API Abuse: Rapid sequential ID enumeration — automated data harvesting.</description>
    <mitre>
      <id>T1190</id>
    </mitre>
    <group>web,attack,api_abuse,pci_dss_6.5.1,pci_dss_11.4,</group>
  </rule>

  <rule id="100315" level="6">
    <if_group>web|accesslog</if_group>
    <url type="pcre2">(?i)(\/api\/)</url>
    <status>500|502|503</status>
    <description>API Abuse: Server error on API endpoint — possible malformed input fuzzing.</description>
    <mitre>
      <id>T1190</id>
    </mitre>
    <group>web,attack,api_abuse,pci_dss_6.5.1,</group>
  </rule>

  <rule id="100316" level="10" frequency="15" timeframe="60">
    <if_matched_sid>100315</if_matched_sid>
    <same_source_ip />
    <description>API Abuse: Many server errors from same IP — API fuzzing attack.</description>
    <mitre>
      <id>T1190</id>
    </mitre>
    <group>web,attack,api_abuse,pci_dss_6.5.1,pci_dss_11.4,</group>
  </rule>

</group>
